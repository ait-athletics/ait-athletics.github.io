# =============================================================
#  愛知工業大学 陸上競技部 公式サイト  .gitignore
# -------------------------------------------------------------
#  ここに書いたファイルは Git（GitHub）の管理に入りません。
#
#  【注意1】このファイルは Git だけのルールです。
#   Netlify のドラッグ&ドロップ公開には効きません。
#   Netlify へ上げるときは「公開用コピーフォルダ」を使ってください
#   （README「Netlify への公開・更新」を参照）。
#
#  【注意2】「中身を推測させるファイル名」をここに書かないこと。
#   （例：名簿.xlsx / 個人情報 / 部員連絡先 など）
#   このファイル自体が公開されうるため、書くと「そこに何かある」
#   というヒントを与えてしまいます。見せたくないファイルは
#   .gitignore に書くのではなく、サイトフォルダの外に置くこと。
#
#  【注意3】「#」は行頭だけがコメントです。
#   パターンの後ろに「#」を書くと、そのまま名前の一部として
#   扱われて効かなくなります。コメントは必ず独立した行に。
# =============================================================

# ----- OS が勝手に作るファイル -----
.DS_Store
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ----- エディタ・ツールの設定 -----
.vscode/
.idea/

# ----- Office の一時ファイル -----
~$*.docx
~$*.xlsx
~$*.pptx

# ----- 作業用・配布物（サイト本体ではない） -----
# publish/ … Netlify 公開用コピーの置き場所
publish/
*.zip
# preview-*.html … 表示確認用のプレビューファイル
preview-*.html

# ----- バックアップ -----
*.bak
*.old
*~

# =============================================================
#  【あえて除外していないもの】
#   news/_drafts/ … 下書きも履歴に残し、復元できるようにするため
#                   （サイト上は従来どおり非表示）
#   content/ images/ js/ css/ … サイト本体。絶対に除外しないこと
#   .gitignore 自体 … 全員で共有する設定なので管理に含める
# =============================================================
